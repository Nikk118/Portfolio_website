<script>
  import emailjs from "@emailjs/browser";

  const form = document.getElementById("contact-form");
  const submitButton = document.getElementById("contact-submit");
  const status = document.getElementById("contact-status");

  emailjs.init("PICry6yXnyFlIF9yK");

  const updateStatus = (message: string, state: "success" | "error") => {
    if (!status) return;
    status.textContent = message;
    status.classList.remove("hidden", "text-red-600", "text-green-600");
    status.classList.add(state === "success" ? "text-green-600" : "text-red-600");
  };

  if (!(form instanceof HTMLFormElement)) {
    console.error("Contact form not found");
  }

  if (!(submitButton instanceof HTMLButtonElement)) {
    console.error("Contact submit button not found");
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!(form instanceof HTMLFormElement) || !(submitButton instanceof HTMLButtonElement)) {
      updateStatus("Contact form is not ready. Please refresh and try again.", "error");
      return;
    }

    submitButton.disabled = true;
    submitButton.textContent = "Sending...";

    try {
      await emailjs.sendForm(
        "service_krp7a0h",
        "template_qp7btg9",
        form
      );

      updateStatus("Message sent successfully!", "success");
      form.reset();
    } catch (error) {
      console.error(error);
      updateStatus("Failed to send message", "error");
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Start Your Project Today";
    }
  });
</script>


