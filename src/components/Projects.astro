---
import { Image } from "astro:assets";
import seluraImage from "../assets/selura.png";
import serviellianceImage from "../assets/image.png";
import talknestImage from "../assets/image1.png";

const projects = [
  {
    title: "Selura (Freelance)",
    subtitle: "E-commerce Platform",
    year: "2025",
    description:
      "Full-stack e-commerce platform developed as a freelance project. Includes secure authentication, product management, cart and checkout flow, address handling, and Razorpay payment integration with a modern responsive UI.",
    tech: ["React", "Vite", "Tailwind CSS", "Node.js", "Express", "MongoDB", "JWT", "Razorpay"],
    liveDemo: "https://seluraofficial.in/",
    github: "Private repository (Client project)",
    image: seluraImage,
  },
  {
    title: "Servielliance",
    subtitle: "UrbanClap Clone",
    year: "2025",
    description:
      "Service marketplace platform enabling users to book professionals in real time. Implemented role-based access, booking lifecycle management, notifications, and image uploads with a scalable backend architecture.",
    tech: ["React", "Vite", "Tailwind", "Zustand", "JWT", "Cloudinary", "Multer", "Nodemailer"],
    liveDemo: "https://servielliance.onrender.com",
    github: "https://github.com/Nikk118/Servilanc",
    image: serviellianceImage,
  },
  {
    title: "TalkNest",
    subtitle: "Chat App",
    year: "2024",
    description:
      "Real-time chat application supporting instant messaging and user authentication. Built using Socket.IO with message persistence and a responsive UI optimized for smooth real-time interactions.",
    tech: ["React", "Node.js", "Express", "MongoDB", "Socket.IO", "Tailwind CSS"],
    liveDemo: "https://chatapp-xn9n.onrender.com",
    github: "https://github.com/Nikk118/chatApp",
    image: talknestImage,
  },
  {
    title: "BlogAgent — Agentic Blog Generation Pipeline",
    subtitle: "AI/ML",
    year: "2025",
    description:
      "Built an agentic blog generation system using LangGraph with a multi-node pipeline: routing, research, orchestration, parallel section writing, and reduction. Implemented fanout worker nodes for concurrent section generation and a reducer subgraph for merging, image decision, and placement. Integrated Tavily web research to fetch and normalize real-time evidence for grounded, citation-backed content. Automated technical image generation and insertion into final markdown output via the Google Gemini API. Shipped a Streamlit frontend with multi-chat session history and tabbed output views: Plan, Evidence, Markdown Preview, Images, and Logs.",
    tech: ["Python", "LangGraph", "Mistral AI", "Tavily", "Streamlit", "Pydantic", "Google Gemini"],
    github: "https://github.com/Nikk118/blogAgent",
  },
  {
    title: "NexChat — Stateful AI Chatbot with Memory",
    subtitle: "Full-stack AI",
    year: "2025",
    description:
      "Built a full-stack AI chatbot with persistent memory backed by LangGraph + PostgreSQL. Implemented a multi-conversation chat system with automatic history management and title generation. Designed a modular FastAPI backend and integrated streaming LLM responses. Wired up tool-calling agents (calculator, web search, weather) and PDF RAG via FAISS for in-chat document Q&A. Enabled stateful conversation flow with per-session memory retrieval across sessions.",
    tech: ["FastAPI", "LangGraph", "PostgreSQL", "Mistral Ai", "Streamlit", "FAISS", "Pydantic"],
    github: "https://github.com/Nikk118/nexchat",
  },
  {
    title: "TimeCapsule — AI Memory & Scheduling Assistant",
    subtitle: "Full-stack App",
    year: "2025",
    description:
      "Developed a full-stack app for timestamped digital capsules — users store messages and schedule future reminders via natural language. Built a LangChain-based AI agent to store, retrieve, and reason over capsule data (e.g 'how many capsules do I have?', 'remind me next Monday'). Implemented scalable REST APIs and client-side state management with Zustand.",
    tech: ["React", "Node.js", "MongoDB", "LangChain", "HuggingFace (Llama 3.1)", "Zustand"],
    github: "https://github.com/Nikk118/timecapsule",
  },
];

const webProjectTitles = ["Selura (Freelance)", "Servielliance", "TalkNest"];
const webProjects = projects.filter((project) => webProjectTitles.includes(project.title));
const aiMlProjects = projects.filter((project) => !webProjectTitles.includes(project.title));

const aiMlMeta = {
  "BlogAgent — Agentic Blog Generation Pipeline": {
    icon: "📝",
    iconBg: "bg-amber-100 text-amber-700",
    stats: [
      { value: "LangGraph", label: "Pipeline" },
      { value: "5+", label: "Nodes" },
      { value: "Gemini", label: "Images" },
    ],
  },
  "NexChat — Stateful AI Chatbot with Memory": {
    icon: "💬",
    iconBg: "bg-purple-100 text-purple-700",
    stats: [
      { value: "PostgreSQL", label: "Persistence" },
      { value: "Streaming", label: "Responses" },
      { value: "Multi-tool", label: "Agents" },
    ],
  },
  "TimeCapsule — AI Memory & Scheduling Assistant": {
    icon: "⏰",
    iconBg: "bg-rose-100 text-rose-700",
    stats: [
      { value: "NLP", label: "Scheduling" },
      { value: "MongoDB", label: "Storage" },
      { value: "Zustand", label: "State" },
    ],
  },
};
---

<section id="projects" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4 text-center">
      Featured Projects
    </h2>
    <p class="text-slate-600 text-center mb-10 max-w-2xl mx-auto">
      Full-stack web apps and AI/ML systems built from scratch
    </p>

    <div class="flex justify-center mb-10">
      <div class="inline-flex items-center gap-2 p-1 bg-slate-100 rounded-full" role="tablist" aria-label="Project categories">
        <button
          id="tab-web"
          type="button"
          role="tab"
          aria-label="Show web development projects"
          aria-selected="true"
          aria-controls="panel-web"
          data-project-tab="web"
          class="project-tab-btn px-5 py-2 rounded-full text-sm font-medium transition-colors bg-slate-900 text-white"
        >
          Web Projects
        </button>
        <button
          id="tab-ai"
          type="button"
          role="tab"
          aria-label="Show AI and machine learning projects"
          aria-selected="false"
          aria-controls="panel-ai"
          data-project-tab="ai"
          class="project-tab-btn px-5 py-2 rounded-full text-sm font-medium transition-colors bg-white text-slate-700 border border-slate-200"
        >
          AI/ML Projects
        </button>
      </div>
    </div>

    <div id="panel-web" role="tabpanel" aria-labelledby="tab-web" class="project-panel opacity-100 transition-opacity duration-300">
      <div class="grid md:grid-cols-1 gap-8">
        {
          webProjects.map((project) => (
            <article class="bg-slate-50 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
              <div class="grid md:grid-cols-2 gap-0">
                <div class="relative h-64 md:h-full overflow-hidden">
                  <Image
                    src={project.image}
                    alt={project.title}
                    class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
                    loading="lazy"
                    widths={[480, 768, 1200]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                  />
                </div>

                <div class="p-8 flex flex-col justify-between">
                  <div>
                    <div class="flex items-center justify-between mb-2">
                      <h3 class="text-3xl font-bold text-slate-900">{project.title}</h3>
                      <span class="text-slate-500 text-sm">{project.year}</span>
                    </div>
                    <p class="text-slate-600 font-medium mb-4">{project.subtitle}</p>
                    <p class="text-slate-700 mb-6 leading-relaxed">{project.description}</p>

                    <div class="flex flex-wrap gap-2 mb-6">
                      {project.tech.map((tech) => <span class="px-3 py-1 bg-white text-slate-700 rounded-full text-sm font-medium shadow-sm">{tech}</span>)}
                    </div>
                  </div>

                  <div class="flex gap-4">
                    <a
                      href={project.liveDemo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-2 px-6 py-3 bg-slate-900 text-white rounded-lg font-medium hover:bg-slate-800 transition-colors"
                    >
                      Live Demo
                    </a>

                    {project.github.startsWith("http") && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-2 px-6 py-3 bg-white text-slate-900 rounded-lg font-medium hover:bg-slate-100 transition-colors border-2 border-slate-200"
                      >
                        GitHub
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div id="panel-ai" role="tabpanel" aria-labelledby="tab-ai" hidden class="project-panel opacity-0 transition-opacity duration-300">
      <div class="grid md:grid-cols-1 gap-8">
        {
          aiMlProjects.map((project) => {
            const meta = aiMlMeta[project.title] ?? { icon: "??", iconBg: "bg-slate-200 text-slate-700", stats: [] };

            return (
              <article class="bg-slate-50 rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300">
                <div class="flex items-start justify-between gap-4 mb-4">
                  <div class="flex items-center gap-4 min-w-0">
                    <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-xl ${meta.iconBg}`} aria-hidden="true">
                      {meta.icon}
                    </div>
                    <div>
                      <h3 class="text-2xl md:text-3xl font-bold text-slate-900 leading-tight">{project.title}</h3>
                    </div>
                  </div>
                  <span class="text-slate-500 text-sm shrink-0">{project.year}</span>
                </div>

                <p class="text-slate-600 font-medium mb-3">{project.subtitle}</p>
                <p class="text-slate-700 leading-relaxed mb-6">{project.description}</p>

                <div class="flex flex-wrap justify-start gap-3 mb-6">
                  {meta.stats.map((stat:any) => (
                    <div class="w-auto bg-white border border-slate-200 rounded-xl px-5 py-3 text-center">
                      <p class="text-2xl font-bold text-slate-900 leading-none">{stat.value}</p>
                      <p class="text-xs text-slate-500 mt-1">{stat.label}</p>
                    </div>
                  ))}
                </div>

                <div class="flex flex-wrap gap-2 mb-6">
                  {project.tech.map((tech) => <span class="px-3 py-1 bg-white text-slate-700 rounded-full text-sm font-medium shadow-sm">{tech}</span>)}
                </div>

                {project.github.startsWith("http") && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-900 rounded-lg font-medium hover:bg-slate-100 transition-colors border-2 border-slate-200"
                  >
                    GitHub
                  </a>
                )}
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  const tabButtons = Array.from(document.querySelectorAll(".project-tab-btn"));
  const panels = {
    web: document.getElementById("panel-web"),
    ai: document.getElementById("panel-ai"),
  };

  let activeTab = "web";

  const setTabState = (tab) => {
    if (tab === activeTab) return;

    tabButtons.forEach((button) => {
      const isActive = button.dataset.projectTab === tab;
      button.setAttribute("aria-selected", isActive ? "true" : "false");
      button.classList.toggle("bg-slate-900", isActive);
      button.classList.toggle("text-white", isActive);
      button.classList.toggle("bg-white", !isActive);
      button.classList.toggle("text-slate-700", !isActive);
      button.classList.toggle("border", !isActive);
      button.classList.toggle("border-slate-200", !isActive);
    });

    const outgoingPanel = panels[activeTab];
    const incomingPanel = panels[tab];

    if (!outgoingPanel || !incomingPanel) return;

    outgoingPanel.classList.remove("opacity-100");
    outgoingPanel.classList.add("opacity-0");

    setTimeout(() => {
      outgoingPanel.hidden = true;
      incomingPanel.hidden = false;
      incomingPanel.classList.remove("opacity-0");
      incomingPanel.classList.add("opacity-100");
    }, 180);

    activeTab = tab;
  };

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const targetTab = button.dataset.projectTab;
      if (targetTab === "web" || targetTab === "ai") {
        setTabState(targetTab);
      }
    });
  });
</script>
