---
const whatsappLink = "https://wa.me/919601330716?text=Hi%20Nikhil%2C%20I%20want%20to%20build%20a%20project%20with%20you.";
---

<section id="local-services" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase mb-3">Local Service Areas</p>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Hire a Developer in Gujarat</h2>
      <p class="text-slate-600 max-w-3xl mx-auto leading-relaxed">
        I help startups, local businesses, and founders launch full-stack MERN products and AI-powered systems across Gujarat,
        including Umbergaon, Vapi, Valsad, and Ahmedabad.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <a href="/developer-in-vapi" class="group rounded-2xl border border-slate-200 p-6 bg-slate-50 hover:bg-white hover:shadow-md transition-all">
        <h3 class="text-2xl font-bold text-slate-900 mb-2">Full Stack and AI Developer in Vapi</h3>
        <p class="text-slate-600 mb-4">MERN development, LangGraph workflows, and custom AI automation for Vapi companies.</p>
        <span class="text-slate-900 font-semibold group-hover:underline">Explore Vapi services</span>
      </a>

      <a href="/developer-in-valsad" class="group rounded-2xl border border-slate-200 p-6 bg-slate-50 hover:bg-white hover:shadow-md transition-all">
        <h3 class="text-2xl font-bold text-slate-900 mb-2">Freelance Developer in Valsad</h3>
        <p class="text-slate-600 mb-4">Web app development plus AI integration for businesses that want measurable growth.</p>
        <span class="text-slate-900 font-semibold group-hover:underline">Explore Valsad services</span>
      </a>

      <a href="/developer-in-ahmedabad" class="group rounded-2xl border border-slate-200 p-6 bg-slate-50 hover:bg-white hover:shadow-md transition-all">
        <h3 class="text-2xl font-bold text-slate-900 mb-2">MERN and AI Developer in Ahmedabad</h3>
        <p class="text-slate-600 mb-4">Build modern products with React, Node.js, and intelligent AI assistants.</p>
        <span class="text-slate-900 font-semibold group-hover:underline">Explore Ahmedabad services</span>
      </a>

      <a href="/ai-developer-umbergaon" class="group rounded-2xl border border-slate-200 p-6 bg-slate-50 hover:bg-white hover:shadow-md transition-all">
        <h3 class="text-2xl font-bold text-slate-900 mb-2">AI Developer in Umbergaon</h3>
        <p class="text-slate-600 mb-4">Agentic AI, RAG systems, and practical automation tailored for local operations.</p>
        <span class="text-slate-900 font-semibold group-hover:underline">Explore Umbergaon AI services</span>
      </a>
    </div>

    <div class="mt-12 rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center">
      <h3 class="text-2xl font-bold text-slate-900 mb-3">Looking for a local technical partner in Gujarat?</h3>
      <p class="text-slate-600 max-w-3xl mx-auto mb-6">
        I work with clients across Ahmedabad, Vapi, Valsad, and Umbergaon on full-stack and AI product delivery.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="px-6 py-3 rounded-lg bg-slate-900 text-white font-semibold hover:bg-slate-800 transition-colors">Get a free consultation</a>
        <a href="/developer-in-ahmedabad" class="px-6 py-3 rounded-lg bg-white border border-slate-300 text-slate-900 font-semibold hover:bg-slate-100 transition-colors">See all local services</a>
      </div>
    </div>
  </div>
</section>
