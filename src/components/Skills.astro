---
const skillSections = [
  {
    label: "LANG",
    labelClass: "bg-slate-900 text-white",
    title: "Languages",
    subtitle: "Programming foundations",
    pillClass: "bg-slate-100 text-slate-800 border-slate-200",
    skills: ["JavaScript", "TypeScript", "Python", "Java", "C++"],
  },
  {
    label: "WEB",
    labelClass: "bg-indigo-600 text-white",
    title: "Frontend",
    subtitle: "Interfaces and UI systems",
    pillClass: "bg-indigo-50 text-indigo-800 border-indigo-200",
    skills: ["React.js", "Svelte", "SvelteKit", "Astro", "Tailwind CSS", "HTML", "CSS", "Bootstrap"],
  },
  {
    label: "API",
    labelClass: "bg-violet-600 text-white",
    title: "Backend & APIs",
    subtitle: "Servers, auth, and services",
    pillClass: "bg-violet-50 text-violet-800 border-violet-200",
    skills: ["Node.js", "Express.js", "FastAPI", "REST APIs", "JWT", "Authentication", "Authorization"],
  },
  {
    label: "DATA",
    labelClass: "bg-amber-500 text-white",
    title: "Databases & Storage",
    subtitle: "Persistence and data layers",
    pillClass: "bg-amber-50 text-amber-800 border-amber-200",
    skills: ["MongoDB", "PostgreSQL", "SQL", "Astra DB", "Firebase"],
  },
  {
    label: "AI",
    labelClass: "bg-emerald-600 text-white",
    title: "AI and ML",
    subtitle: "Models, retrieval, and agents",
    pillClass: "bg-emerald-50 text-emerald-800 border-emerald-200",
    skills: ["ML Algorithms", "Deep Learning", "NLP & Retrieval", "Tools & Libraries"],
  },
  {
    label: "FMW",
    labelClass: "bg-teal-600 text-white",
    title: "AI Frameworks",
    subtitle: "Agent and workflow orchestration",
    pillClass: "bg-teal-50 text-teal-800 border-teal-200",
    skills: ["LangChain", "LangGraph", "LangFlow"],
  },
  {
    label: "TOOLS",
    labelClass: "bg-rose-600 text-white",
    title: "Tools & Deployment",
    subtitle: "Workflow and shipping",
    pillClass: "bg-rose-50 text-rose-800 border-rose-200",
    skills: ["Git", "GitHub", "Postman", "VS Code", "Docker", "Render", "Vercel", "Cloudinary"],
  },
  {
    label: "SYS",
    labelClass: "bg-cyan-600 text-white",
    title: "Concepts & Practices",
    subtitle: "Engineering thinking",
    pillClass: "bg-cyan-50 text-cyan-800 border-cyan-200",
    skills: ["OOP", "Data Structures and Algorithms", "Scalable Architecture", "Debugging and Testing Mindset", "Agile Workflow", "Clean Code Practices", "Problem Solving"],
  },
];

const whatsappLink = "https://wa.me/919601330716?text=Hi%20Nikhil%2C%20I%20want%20to%20build%20a%20project%20with%20you.";
---

<section id="skills" class="py-50 px-4 bg-gradient-to-br from-slate-50 via-white to-slate-100">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold tracking-[0.25em] text-slate-500 uppercase mb-3">My Stack</p>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Tech Skills</h2>
      <p class="text-slate-600 max-w-3xl mx-auto">
        A practical toolkit for building production-ready web products and AI-powered experiences.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-6">
      {skillSections.map((section) => (
        <article class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-5">
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center text-xs font-bold ${section.labelClass}`} aria-hidden="true">
              {section.label}
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900">{section.title}</h3>
              <p class="text-slate-500 text-sm">{section.subtitle}</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            {section.skills.map((skill) => (
              <span class={`px-3 py-1.5 rounded-lg text-sm font-medium border ${section.pillClass}`}>
                {skill}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-slate-600 mb-5">Want this stack applied to your product with business-first execution?</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="px-6 py-3 rounded-lg bg-slate-900 text-white font-semibold hover:bg-slate-800 transition-colors">Start your project today</a>
        <a href="/#projects" class="px-6 py-3 rounded-lg bg-white border border-slate-300 text-slate-900 font-semibold hover:bg-slate-100 transition-colors">View my work</a>
      </div>
    </div>
  </div>
</section>
