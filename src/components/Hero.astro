---
---

<section
  id="home"
  class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 px-4"
>
  <div class="max-w-5xl mx-auto text-center animate-in">

    <!-- Location -->
    <div class="flex items-center justify-center gap-2 mb-4">
      <!-- MapPin icon -->
      <svg
        class="w-5 h-5 text-slate-600"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path d="M12 22s7-4.35 7-11a7 7 0 1 0-14 0c0 6.65 7 11 7 11z"/>
        <circle cx="12" cy="11" r="2.5"/>
      </svg>

      <p class="text-slate-600 text-sm">
        Ahemdabad, Gujarat, India
      </p>
    </div>

    <!-- Name -->
    <h1 class="text-5xl md:text-7xl font-bold text-slate-900 mb-4">
      Nikhil Yagik
    </h1>

    <!-- Subtitle -->
    <p class="text-xl md:text-2xl text-slate-700 mb-8 max-w-3xl mx-auto leading-relaxed">
      AI/ML Developer | MCA Student | Full-Stack MERN Developer
    </p>

    <!-- Social Links -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-12">

      <!-- Github -->
      <a
        href="https://github.com/Nikk118"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        class="text-slate-600 hover:text-slate-900 transition-colors"
      >
        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 .6A12 12 0 0 0 8.2 24c.6.12.82-.25.82-.56v-2.1c-3.34.74-4.05-1.42-4.05-1.42-.55-1.37-1.33-1.73-1.33-1.73-1.08-.74.08-.73.08-.73 1.2.08 1.84 1.2 1.84 1.2 1.05 1.8 2.76 1.28 3.44.97.1-.76.4-1.28.73-1.57-2.67-.3-5.48-1.33-5.48-5.92 0-1.3.47-2.37 1.23-3.2-.12-.3-.53-1.5.12-3.14 0 0 1-.32 3.3 1.22a11.5 11.5 0 0 1 6 0c2.28-1.54 3.28-1.22 3.28-1.22.67 1.64.25 2.85.13 3.14.77.83 1.23 1.9 1.23 3.2 0 4.6-2.82 5.61-5.5 5.91.41.35.78 1.04.78 2.1v3.13c0 .31.22.68.83.56A12 12 0 0 0 12 .6z"/>
        </svg>
      </a>

      <!-- Linkedin -->
      <a
        href="https://linkedin.com/in/nikhilyagik"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
        class="text-slate-600 hover:text-slate-900 transition-colors"
      >
        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.03-1.84-3.03-1.84 0-2.12 1.44-2.12 2.93v5.68H9.37V9h3.42v1.56h.05c.48-.9 1.64-1.84 3.37-1.84 3.6 0 4.27 2.37 4.27 5.45v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/>
        </svg>
      </a>

      <!-- Mail -->
      <a
        href="mailto:nikhilyagik2004@gmail.com"
        aria-label="Send email to Nikhil Yagik"
        class="text-slate-600 hover:text-slate-900 transition-colors"
      >
        <svg class="w-6 h-6 stroke-current" fill="none" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2"/>
          <path d="m4 7 8 6 8-6"/>
        </svg>
      </a>

    </div>

    <!-- Buttons -->
    <div class="flex flex-wrap items-center justify-center gap-4">

      <button
        onclick="scrollToSection('projects')"
        class="px-8 py-4 bg-white text-slate-900 rounded-lg font-medium hover:bg-slate-50 transition-all hover:scale-105 active:scale-95 shadow-lg border-2 border-slate-200"
      >
        View Projects
      </button>

           <details class="group relative inline-block" id="resume-dropdown">
        <summary class="list-none cursor-pointer px-8 py-4 bg-slate-900 text-white rounded-lg font-medium hover:bg-slate-800 transition-all hover:scale-105 active:scale-95 shadow-lg border-2 border-slate-900 flex items-center gap-2 whitespace-nowrap [&::-webkit-details-marker]:hidden">
          <span class="whitespace-nowrap">View Resume</span>
          <span aria-hidden="true" class="inline-block transition-transform duration-200 group-open:rotate-180">&darr;</span>
        </summary>

        <div class="resume-menu absolute right-0 top-full z-50 mt-2 w-max min-w-full max-w-[calc(100vw-2rem)] rounded-xl border border-slate-200 bg-white shadow-lg overflow-hidden text-left whitespace-nowrap">
          <a href="/resume_fullstack.pdf" target="_blank" rel="noopener noreferrer" aria-label="Open Full Stack Developer resume PDF" class="flex items-center justify-between gap-5 px-4 py-3 text-slate-800 hover:bg-slate-50 transition-colors">
            <span class="whitespace-nowrap">
              <span class="block text-lg font-semibold leading-tight whitespace-nowrap">Full Stack Developer</span>
              <span class="block text-sm text-slate-500 whitespace-nowrap">React | Node | MongoDB</span>
            </span>
            <span class="shrink-0 text-sm font-medium text-blue-600 whitespace-nowrap">Open &nearr;</span>
          </a>

          <a href="/resume_ML.pdf" target="_blank" rel="noopener noreferrer" aria-label="Open AI / ML Engineer resume PDF" class="flex items-center justify-between gap-5 border-t border-slate-100 px-4 py-3 text-slate-800 hover:bg-slate-50 transition-colors">
            <span class="whitespace-nowrap">
              <span class="block text-lg font-semibold leading-tight whitespace-nowrap">AI / ML Engineer</span>
              <span class="block text-sm text-slate-500 whitespace-nowrap">PyTorch | Transformers | CV</span>
            </span>
            <span class="shrink-0 text-sm font-medium text-blue-600 whitespace-nowrap">Open &nearr;</span>
          </a>
        </div>
      </details>




      <button
        onclick="scrollToSection('contact')"
        class="px-8 py-4 bg-white text-slate-900 rounded-lg font-medium hover:bg-slate-50 transition-all hover:scale-105 active:scale-95 shadow-lg border-2 border-slate-200"
      >
        Contact Me
      </button>

    </div>

  </div>
</section>

<script is:inline>
  window.scrollToSection = (id) => {
    document.getElementById(id)?.scrollIntoView({
      behavior: "smooth"
    });
  };

  const resumeDropdown = document.getElementById("resume-dropdown");

  document.addEventListener("click", (event) => {
    if (!resumeDropdown) return;
    if (!resumeDropdown.contains(event.target)) {
      resumeDropdown.removeAttribute("open");
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      resumeDropdown?.removeAttribute("open");
    }
  });
</script>

<style>
  .animate-in {
    animation: fade-up 0.6s ease-out;
  }

  .resume-menu {
    transform-origin: top right;
  }

  details[open] .resume-menu {
    animation: dropdown-fade-slide 180ms ease-out;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dropdown-fade-slide {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>











