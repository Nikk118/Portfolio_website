---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Skills from "../components/Skills.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Chatbot from "../components/Chatbot.astro";
---

<MainLayout
  title="Nikhil Yagik | Full-Stack Developer & AI/ML Engineer"
  description="Explore Nikhil Yagik's portfolio featuring full-stack web projects, AI/ML work, technical skills, and contact information for freelance and full-time roles."
  image="/logo.png"
>
  <div class="min-h-screen">
    <Navbar />
    <Hero />
    <About />
    <Skills />
    <Projects />
    <Contact />
    <Footer />
    <Chatbot />
  </div>
</MainLayout>
